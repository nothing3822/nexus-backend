# ── Nexus Chat - Environment Variables ──────────────────────
# Locally: SQLite (koi setup nahi chahiye)
# Railway: Wahan se PostgreSQL URL milega — wahan paste karna

DATABASE_URL=sqlite:///./nexus.db

# Yeh seedha change karo — koi bhi random string
SECRET_KEY=nexus-change-this-to-random-secret-abc123xyz789

# Railway deploy ke baad PostgreSQL URL yahan aayega:
# DATABASE_URL=postgresql://user:password@host:5432/nexusdb
